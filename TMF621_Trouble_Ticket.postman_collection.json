			"name": "1. Create Ticket (POST)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData.id) {",
							"    pm.globals.set(\"ticket_id\", jsonData.id);",
							"    console.log(\"Saved ticket_id: \" + jsonData.id);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"VOD Billing Complaint\",\n  \"description\": \"December bill shows VOD charge for movie I could not watch due to buffering\",\n  \"severity\": \"Minor\",\n  \"ticketType\": \"Bill Dispute\",\n  \"externalId\": \"CRM-2024-9921\",\n  \"priority\": \"High\",\n  \"requestedResolutionDate\": \"2026-06-15T00:00:00\",\n  \"relatedParty\": [\n    {\n      \"role\": \"customer\",\n      \"name\": \"Mr Jack Hide\"\n    }\n  ],\n  \"channel\": {\n    \"id\": \"8774\",\n    \"name\": \"Self Service\"\n  }\n}"
				},
				"url": {
					"raw": "http://localhost:8080/troubleTicket/v2/troubleTicket",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"troubleTicket",
						"v2",
						"troubleTicket"
					]
				}
			},
			"response": []
		},
